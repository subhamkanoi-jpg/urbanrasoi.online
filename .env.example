# Meta (Facebook/Instagram) ads configuration
# Set these in Vercel → Project → Settings → Environment Variables.

# Meta Pixel ID (Events Manager → Data Sources → your pixel). Required for all
# browser-side tracking (PageView, ViewContent, Lead, Contact).
NEXT_PUBLIC_META_PIXEL_ID=

# Conversions API access token (Events Manager → your pixel → Settings →
# Generate access token). Enables server-side Lead/Contact events, deduplicated
# against the browser pixel. Strongly recommended before scaling spend.
META_CONVERSIONS_API_TOKEN=

# Optional: override the pixel ID used by the Conversions API route.
# Defaults to NEXT_PUBLIC_META_PIXEL_ID.
META_PIXEL_ID=

# Optional: test event code (Events Manager → Test Events) to verify
# Conversions API events before going live. Remove in production.
META_TEST_EVENT_CODE=

# Meta domain verification code (Business Manager → Brand Safety → Domains →
# urbanrasoi.online → Meta-tag verification). Only the content value, e.g.
# "abc123". Required to configure web events and run ads reliably.
NEXT_PUBLIC_META_DOMAIN_VERIFICATION=
